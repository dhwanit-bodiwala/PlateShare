<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/saffron"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <!-- Back -->
            <TextView
                android:id="@+id/back_btn_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← BACK"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp"/>

            <!-- Eyebrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DONATION DETAILS"
                android:textColor="@color/green_deep"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <!-- Food name -->
            <TextView
                android:id="@+id/details_food_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Food Name"
                android:textColor="@color/text_primary"
                android:textSize="40sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="36dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/black"
                android:layout_marginBottom="28dp"/>

            <!-- Food type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOOD TYPE"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/details_food_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"/>

            <!-- Quantity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUANTITY"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/details_quantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quantity"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"/>

            <!-- Expiry -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPIRY DATE"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/details_expiry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expiry"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"/>

            <!-- Allergies -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALLERGIES"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/details_allergies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allergies"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:layout_marginBottom="28dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/black"
                android:layout_marginBottom="20dp"/>

            <!-- Donor name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DONATED BY"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/details_donor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Donor Name"
                android:textColor="@color/green_deep"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="36dp"/>

            <!-- Claim button -->
            <Button
                android:id="@+id/claim_btn_details"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_primary"
                android:text="CLAIM THIS DONATION →"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:stateListAnimator="@null"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>