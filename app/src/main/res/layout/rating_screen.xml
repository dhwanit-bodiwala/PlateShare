<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/saffron"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <!-- Eyebrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RATE YOUR EXPERIENCE"
                android:textColor="@color/green_deep"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW WAS IT?"
                android:textColor="@color/text_primary"
                android:textSize="40sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="8dp"/>

            <!-- Donor name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rating donation from"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/rating_donor_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Donor Name"
                android:textColor="@color/green_deep"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="36dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/black"
                android:layout_marginBottom="32dp"/>

            <!-- Reliability -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RELIABILITY"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/reliability_bad"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="BAD"
                    android:textColor="@color/saffron_dark"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/reliability_average"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="AVERAGE"
                    android:textColor="@color/saffron_dark"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/reliability_good"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="GOOD"
                    android:textColor="@color/saffron_dark"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

            <!-- Communication -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMMUNICATION"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="36dp">

                <Button
                    android:id="@+id/communication_bad"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="BAD"
                    android:textColor="@color/saffron_dark"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/communication_average"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="AVERAGE"
                    android:textColor="@color/saffron_dark"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/communication_good"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="GOOD"
                    android:textColor="@color/saffron_dark"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/black"
                android:layout_marginBottom="24dp"/>

            <!-- Submit -->
            <Button
                android:id="@+id/submit_rating_btn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_primary"
                android:text="SUBMIT RATING →"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:stateListAnimator="@null"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>