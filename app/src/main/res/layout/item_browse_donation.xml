<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_input"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Food name + food type row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/browse_food_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Food Name"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"/>

        <TextView
            android:id="@+id/browse_food_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type"
            android:textColor="@color/saffron_dark"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:gravity="center_vertical"/>

    </LinearLayout>

    <TextView
        android:id="@+id/browse_quantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quantity"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/browse_expiry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expiry"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="2dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_hint"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/browse_donor_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DONATED BY: Donor Name"
        android:textColor="@color/green_deep"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"/>

</LinearLayout>