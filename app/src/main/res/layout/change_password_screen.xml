<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/saffron"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <!-- Eyebrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLATESHARE"
                android:textColor="@color/green_deep"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHANGE\nPASSWORD."
                android:textColor="@color/text_primary"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your new password below"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="36dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/black"
                android:layout_marginBottom="32dp"/>

            <!-- New password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/new_password_change"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:inputType="textPassword"
                android:hint="Min. 6 characters"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="18dp"/>

            <!-- Confirm password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRM PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/confirm_password_change"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:inputType="textPassword"
                android:hint="Re-enter password"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="18dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/black"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"/>

            <!-- Submit button -->
            <Button
                android:id="@+id/submit_change"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_primary"
                android:text="UPDATE PASSWORD →"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:stateListAnimator="@null"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>