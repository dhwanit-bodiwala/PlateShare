<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/saffron"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:text="PLATESHARE"
                android:textColor="@color/saffron_dark"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:text="CREATE\nACCOUNT."
                android:textColor="@color/text_primary"
                android:textSize="44sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:background="@color/border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="FULL NAME"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/name_signup"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:hint="Your name"
                android:inputType="textPersonName"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="EMAIL"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/email_signup"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/password_signup"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:hint="Min. 6 characters"
                android:inputType="textPassword"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="CONFIRM PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/confirm_password_signup"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:hint="Re-enter password"
                android:inputType="textPassword"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="PHONE"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/phone_signup"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:hint="10-digit number"
                android:inputType="phone"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="ADDRESS"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/address_signup"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Your full address"
                android:inputType="textMultiLine"
                android:paddingHorizontal="14dp"
                android:paddingVertical="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <!-- ============ ROLE SELECTION ============ -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:text="I AM A"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <RadioGroup
                android:id="@+id/role_group_signup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_donor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/green_deep"
                    android:fontFamily="monospace"
                    android:text="DONOR"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/radio_receiver"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/green_deep"
                    android:fontFamily="monospace"
                    android:text="RECEIVER"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

            </RadioGroup>

            <!-- ============ DONOR TYPE (hidden unless role = Donor) ============ -->

            <LinearLayout
                android:id="@+id/donor_type_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:text="DONOR TYPE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <RadioGroup
                    android:id="@+id/donor_type_group_signup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radio_individual"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/green_deep"
                        android:fontFamily="monospace"
                        android:text="INDIVIDUAL"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/radio_organization"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/green_deep"
                        android:fontFamily="monospace"
                        android:text="ORGANIZATION"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                </RadioGroup>

            </LinearLayout>

            <!-- ============ ORGANIZATION FIELDS (hidden unless donor_type = Organization) ============ -->

            <LinearLayout
                android:id="@+id/organization_fields_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:text="ORGANIZATION NAME"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/organization_name_signup"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="e.g. Roti Ghar"
                    android:inputType="text"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:text="CONTACT PERSON"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/contact_person_signup"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input"
                    android:hint="Person to contact"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:background="@color/border" />

            <Button
                android:id="@+id/signup_signup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_primary"
                android:letterSpacing="0.08"
                android:stateListAnimator="@null"
                android:text="CREATE ACCOUNT →"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/login_signup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="ALREADY HAVE AN ACCOUNT? SIGN IN →"
                android:textColor="@color/green_deep"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>