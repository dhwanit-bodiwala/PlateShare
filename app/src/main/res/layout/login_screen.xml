<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/saffron"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLATESHARE"
                android:textColor="@color/saffron_dark"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGN IN."
                android:textColor="@color/text_primary"
                android:textSize="52sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/border"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/email_login"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:inputType="textEmailAddress"
                android:hint="you@example.com"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/password_login"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:inputType="textPassword"
                android:hint="••••••••"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingHorizontal="14dp"/>

            <TextView
                android:id="@+id/forgot_password_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FORGOT PASSWORD?"
                android:textColor="@color/saffron_dark"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"/>

            <Button
                android:id="@+id/login_login"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_primary"
                android:text="SIGN IN"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="32dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/guest_login"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_secondary"
                android:text="CONTINUE AS GUEST"
                android:textColor="@color/saffron_dark"
                android:textSize="13sp"
                android:letterSpacing="0.08"
                android:layout_marginTop="12dp"
                android:stateListAnimator="@null"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/border"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/signup_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NO ACCOUNT? CREATE ONE →"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>