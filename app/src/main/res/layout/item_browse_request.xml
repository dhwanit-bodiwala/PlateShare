<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_input"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/browse_request_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Request Title"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"/>

    <TextView
        android:id="@+id/browse_request_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="6dp"
        android:maxLines="2"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/browse_request_quantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quantity Needed"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/browse_request_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Location"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="2dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_hint"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/browse_request_receiver_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REQUESTED BY: Receiver Name"
        android:textColor="@color/green_deep"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"/>

</LinearLayout>